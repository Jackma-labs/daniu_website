# Model providers. Keep real keys only in .env.local or deployment secrets.
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-v4-pro"

MINIMAX_API_KEY=""
MINIMAX_BASE_URL="https://api.minimax.io/v1"
MINIMAX_MODEL="MiniMax-M2.5"

DANIU_LOCAL_LLM_BASE_URL="https://landingx.cn/deepconf/v1"
DANIU_LOCAL_LLM_API_KEY=""
DANIU_LOCAL_LLM_MODEL="qwen2.5-32b-deepconf"
DANIU_AUTO_PROVIDER_ORDER="deepseek,minimax,local"

# Optional. Increases GitHub API limits for importing public/private Skill repos.
GITHUB_TOKEN=""

# Local appliance account. Change before production.
DANIU_ADMIN_ACCOUNT="admin@daniu.local"
DANIU_ADMIN_PASSWORD="changeme"
DANIU_SESSION_SECRET=""

# Runtime storage. In Docker this should be mounted to a persistent volume.
DANIU_STORAGE_DIR=".daniu"

# Backend limits.
DANIU_MAX_UPLOAD_MB="50"
DANIU_MAX_UPLOAD_FILES="10"
DANIU_ENABLE_DEMO_DATA="false"
DANIU_ALLOWED_UPLOAD_EXTENSIONS=".txt,.md,.csv,.json,.html,.xml,.log,.pdf,.docx,.xlsx,.xlsm,.png,.jpg,.jpeg,.webp,.mp3,.wav,.m4a,.mp4,.mov,.avi"
DANIU_MAX_ZIP_ENTRIES="300"
DANIU_MAX_DECOMPRESSED_BYTES="209715200"
DANIU_MAX_JSON_BYTES="262144"
DANIU_CHAT_MESSAGE_LIMIT="12"
DANIU_CHAT_MESSAGE_MAX_CHARS="12000"
DANIU_RAG_SOURCE_LIMIT="5"
DANIU_MODEL_TIMEOUT_MS="60000"
DANIU_MODEL_MAX_TOKENS="2048"

# In-memory per-instance rate limits.
DANIU_RATE_LIMIT_WINDOW_MS="60000"
DANIU_LOGIN_RATE_LIMIT="10"
DANIU_CHAT_RATE_LIMIT="60"
DANIU_UPLOAD_RATE_LIMIT="20"
